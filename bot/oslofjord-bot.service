[Unit]
Description=Oslofjord domki - bot Telegram
After=network-online.target
Wants=network-online.target

[Service]
WorkingDirectory=/opt/oslofjord-domki/bot
EnvironmentFile=/opt/oslofjord-domki/bot/.env
ExecStart=/usr/bin/node bot.js
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
